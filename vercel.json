{
  "functions": {
    "app/api/ingest/route.ts": { "maxDuration": 60 },
    "app/api/chat/route.ts":   { "maxDuration": 60 },
    "app/api/stats/route.ts":  { "maxDuration": 30 }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "same-origin" },
        { "key": "X-Content-Type-Options",       "value": "nosniff" }
      ]
    }
  ]
}
