# ─────────────────────────────────────────────────────────────────────────────
# DocuMind v8 — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Auth ─────────────────────────────────────────────────────────────────────
# Required. 32+ char secret for HMAC session signing.
# Generate: openssl rand -base64 32
AUTH_SECRET=change-me-generate-with-openssl-rand-base64-32

# ── Database (Neon recommended) ───────────────────────────────────────────────
# Required for persistent storage. Enable the 'vector' extension in Neon first:
#   Neon Dashboard → Extensions → search 'vector' → Enable
DATABASE_URL=postgresql://username:password@ep-your-project.region.aws.neon.tech/neondb?sslmode=require

# Set to 'false' only for local Postgres without SSL
# DATABASE_SSL=true

# ── AI Provider ──────────────────────────────────────────────────────────────
# Without these, upload and search work but AI chat is disabled.
# Gemini is free and recommended for new users:
#   Get key at: https://aistudio.google.com/app/apikey

LLM_API_KEY=your-api-key-here

# Base URL for OpenAI-compatible providers:
#   Gemini:     https://generativelanguage.googleapis.com/v1beta/openai
#   Groq:       https://api.groq.com/openai/v1
#   Together:   https://api.together.xyz/v1
#   Ollama:     http://localhost:11434/v1
#   OpenAI:     (leave blank — uses default)
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai

# Chat model name (must be supported by your provider)
#   Gemini:     gemini-2.5-flash
#   OpenAI:     gpt-4o-mini
#   Groq:       llama-3.3-70b-versatile
#   Ollama:     llama3.2
LLM_CHAT_MODEL=gemini-2.5-flash

# Embedding model — MUST match EMBED_DIM below
#   Gemini:     gemini-embedding-001    → 768
#   OpenAI:     text-embedding-3-small  → 1536
LLM_EMBED_MODEL=gemini-embedding-001

# Dimension of the embedding vectors. Must match your model exactly.
# Changing this after uploading documents requires deleting all docs and re-uploading.
#   768  → Gemini / most open-source models
#   1536 → OpenAI text-embedding-3-small
#   3072 → OpenAI text-embedding-3-large
EMBED_DIM=768
