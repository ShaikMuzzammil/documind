# DocuMind Environment Variables
# Copy this file to .env.local and fill in your values.
# Full setup guide: see README.md

# ────────────────────────────────────────────────
# REQUIRED — Auth
# ────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
AUTH_SECRET=

# ────────────────────────────────────────────────
# AI Provider (for Chat answers)
# Without this, upload/search/indexing still work.
# See README.md for supported providers.
# ────────────────────────────────────────────────
LLM_API_KEY=
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
LLM_CHAT_MODEL=gemini-2.5-flash
LLM_EMBED_MODEL=gemini-embedding-001

# ────────────────────────────────────────────────
# Database (production only)
# Free options: neon.tech · supabase.com · railway.app
# Without this, data is stored locally in /tmp.
# ────────────────────────────────────────────────
DATABASE_URL=

# ────────────────────────────────────────────────
# Email (optional)
# resend.com — sends welcome emails on signup
# ────────────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=noreply@yourdomain.com

# ────────────────────────────────────────────────
# Advanced (optional)
# ────────────────────────────────────────────────
# EMBED_DIM=768
