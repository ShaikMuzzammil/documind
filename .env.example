# ──────────────────────────────────────────────────────────────────────────────
# DocuMind — Environment Variables
# Copy this file to .env.local for local development.
# Set these as environment variables in your Vercel/hosting dashboard.
# ──────────────────────────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────────────────────────

# Random string for signing session cookies (min 32 chars)
# Generate: openssl rand -base64 32
AUTH_SECRET=your-secret-here

# Public URL of your deployment (no trailing slash)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# ── AI answers (highly recommended) ───────────────────────────────────────────

# API key for the answer / embedding provider (Gemini by default)
# Get a free key at: https://aistudio.google.com/apikey
LLM_API_KEY=your-gemini-api-key

# Override base URL if using a different OpenAI-compatible provider
# Default: https://generativelanguage.googleapis.com/v1beta/openai
# LLM_BASE_URL=https://api.openai.com/v1

# Override chat model name (default: gemini-2.5-flash)
# LLM_CHAT_MODEL=gemini-2.5-flash

# Override embedding model name (default: gemini-embedding-001)
# LLM_EMBED_MODEL=gemini-embedding-001

# Embedding vector dimensions (default: 768, must match your pgvector column)
# EMBED_DIM=768

# ── Database (optional but recommended for production) ─────────────────────────

# Postgres connection string with the pgvector extension enabled
# Free options: https://neon.tech  or  https://supabase.com
# Without this, a local JSON file store is used (resets on each deploy)
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Set to 'false' only for local Postgres without SSL
# DATABASE_SSL=true

# ── Email (optional) ──────────────────────────────────────────────────────────

# Resend API key for welcome emails (https://resend.com)
# RESEND_API_KEY=re_...

# Verified sender address in Resend
# EMAIL_FROM=DocuMind <hello@yourdomain.com>
