# ─── Required ────────────────────────────────────────────────────────────────
AI_API_KEY=           # Your AI API key (from your provider dashboard)
AUTH_SECRET=          # Random string: openssl rand -base64 32
NEXT_PUBLIC_APP_URL=  # Your deployment URL e.g. https://documind.vercel.app

# ─── Database (optional — leave empty to use local JSON storage) ─────────────
DATABASE_URL=         # PostgreSQL connection string with pgvector
DATABASE_SSL=true     # Set false for local dev without SSL

# ─── Email (optional — welcome emails) ───────────────────────────────────────
RESEND_API_KEY=       # From resend.com
EMAIL_FROM=           # e.g. DocuMind <noreply@yourdomain.com>
