# ── Required ──────────────────────────────────────────────────────────
# Random 32-character secret for signing session tokens.
# Generate one with: openssl rand -hex 32
AUTH_SECRET=change-this-to-a-random-32-char-secret

# ── AI / LLM ──────────────────────────────────────────────────────────
# Required to enable AI-generated answers in Chat.
# Without this, upload / index / search still work.
# See README.md → "AI / LLM provider" for full setup instructions.
LLM_API_KEY=
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
LLM_CHAT_MODEL=gemini-2.5-flash

# ── Database ──────────────────────────────────────────────────────────
# Optional but strongly recommended for production deployments.
# Without this, data is stored in /tmp and will reset on Vercel redeploy.
# See README.md → "Database" for setup instructions.
DATABASE_URL=

# ── Email ─────────────────────────────────────────────────────────────
# Optional. Sends a welcome email on registration (requires Resend).
# See README.md → "Email" for setup instructions.
RESEND_API_KEY=
EMAIL_FROM=
