# DocuMind environment variables
# Copy to .env.local for local development:
#   cp .env.example .env.local

# App URL used in generated links and email content.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Required in production. Generate a long random value:
#   openssl rand -base64 32
AUTH_SECRET=

# AI provider. OpenAI is the simplest because it supports both chat and embeddings.
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_CHAT_MODEL=gpt-4o-mini
LLM_EMBED_MODEL=text-embedding-3-small

# Production database. Use Postgres with pgvector, such as Neon or Supabase.
# Leave empty locally to use the git-ignored ./data JSON store.
DATABASE_URL=
DATABASE_SSL=true

# Optional welcome email for new accounts. DocuMind uses Resend's HTTP API.
RESEND_API_KEY=
EMAIL_FROM=DocuMind <onboarding@yourdomain.com>
