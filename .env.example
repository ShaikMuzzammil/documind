# DocuMind environment variables
# Copy to .env.local (git-ignored) and fill in real values:
#   cp .env.example .env.local

# ── LLM + embeddings provider (OpenAI-compatible) ────────────────────────
# Works with any OpenAI-style API. Free options:
#   - Groq:     https://console.groq.com   (fast, generous free tier)
#   - OpenAI:   https://platform.openai.com
#   - Together: https://together.ai

# API key for the provider.
LLM_API_KEY=

# Base URL of the OpenAI-compatible endpoint.
#   Groq:    https://api.groq.com/openai/v1
#   OpenAI:  https://api.openai.com/v1
LLM_BASE_URL=https://api.groq.com/openai/v1

# Chat model name (provider-specific).
#   Groq example:   llama-3.3-70b-versatile
#   OpenAI example: gpt-4o-mini
LLM_CHAT_MODEL=llama-3.3-70b-versatile

# Embeddings model name.
#   OpenAI example: text-embedding-3-small
# If your provider has no embeddings endpoint, DocuMind falls back to a
# built-in local hashing embedder so the app still works end-to-end.
LLM_EMBED_MODEL=text-embedding-3-small
