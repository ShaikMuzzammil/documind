# ============================================================
# DocuMind — Environment Variables
# Copy to .env.local for local development:
#   cp .env.example .env.local
# ============================================================

# ------ App ------
# Public URL used in links and emails (no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ------ Security ------
# Required in production. Generate with: openssl rand -base64 32
AUTH_SECRET=

# ------ Gemini AI ------
# Get your API key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Optional overrides (defaults shown)
# GEMINI_CHAT_MODEL=gemini-2.0-flash
# GEMINI_EMBED_MODEL=text-embedding-004

# ------ Database ------
# Production: Postgres + pgvector (Neon, Supabase, or self-hosted)
# Leave empty locally → uses git-ignored ./data JSON store
DATABASE_URL=
DATABASE_SSL=true

# ------ Email (optional) ------
# Welcome emails via Resend (https://resend.com)
RESEND_API_KEY=
EMAIL_FROM=DocuMind <noreply@yourdomain.com>
