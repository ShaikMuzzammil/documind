# =============================================================
# DocuMind v2 — Environment Variables
# Copy to .env.local:  cp .env.example .env.local
# =============================================================

# ── App URL (no trailing slash) ──────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Auth (REQUIRED in production) ────────────────────────────
# Generate: openssl rand -base64 32
AUTH_SECRET=

# ── Gemini AI (REQUIRED for AI answers) ──────────────────────
# Get free key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Optional: override models (defaults shown)
# GEMINI_CHAT_MODEL=gemini-2.0-flash
# GEMINI_EMBED_MODEL=text-embedding-004

# ── Database (leave empty → local JSON store) ────────────────
# Production: Neon / Supabase / any Postgres with pgvector
# Example:    postgresql://user:pass@host/db?sslmode=require
DATABASE_URL=
DATABASE_SSL=true

# ── Email — optional welcome email via Resend ────────────────
# Get key: https://resend.com
RESEND_API_KEY=
EMAIL_FROM=DocuMind <noreply@yourdomain.com>
