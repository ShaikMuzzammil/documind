# ═══════════════════════════════════════════════════
#   DocuMind v3 — Environment Variables
#   Next.js 16.2.9 | github.com/YOUR_USERNAME/documind
# ═══════════════════════════════════════════════════

# ── Required ─────────────────────────────────────────
AI_API_KEY=           # Get free key: aistudio.google.com
AUTH_SECRET=          # openssl rand -base64 32
NEXT_PUBLIC_APP_URL=  # https://your-project.vercel.app  (no trailing slash)

# ── Database ─────────────────────────────────────────
# Leave empty → uses local .data/ JSON store (dev/demo)
# Fill in   → uses PostgreSQL + pgvector (production)
DATABASE_URL=         # postgresql://user:pass@host/db?sslmode=require
DATABASE_SSL=true     # Set false for local Postgres without SSL

# ── AI Model Overrides (optional) ────────────────────
AI_CHAT_MODEL=gemini-2.0-flash    # Streaming chat model
AI_EMBED_MODEL=text-embedding-004  # 768-dim embedding model

# ── Email (optional) ─────────────────────────────────
RESEND_API_KEY=       # resend.com — for welcome emails
EMAIL_FROM=           # DocuMind <noreply@yourdomain.com>
